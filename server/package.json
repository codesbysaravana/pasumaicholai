{
  "name": "ascend-server",
  "version": "1.0.0",
  "description": "Ascend backend API server",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"scripts/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"scripts/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "seed": "tsx scripts/seedDB.ts",
    "seed:crops": "tsx scripts/seedCrops.ts",
    "populate:wards": "tsx scripts/populateWardMappings.ts",
    "test:sns:e2e": "tsx scripts/testSnsE2E.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-comprehend": "^3.1004.0",
    "@aws-sdk/client-polly": "^3.1004.0",
    "@aws-sdk/client-s3": "^3.1004.0",
    "@aws-sdk/client-sns": "^3.1004.0",
    "@aws-sdk/client-transcribe": "^3.1004.0",
    "@aws-sdk/s3-request-presigner": "^3.1004.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "csv-parser": "^3.2.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.2.4",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "openai": "^6.27.0",
    "razorpay": "^2.9.6",
    "socket.io": "^4.7.5",
    "stripe": "^20.4.0",
    "winston": "^3.13.0",
    "ws": "^8.19.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.14.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^7.11.0",
    "@typescript-eslint/parser": "^7.11.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "prettier": "^3.3.2",
    "tsx": "^4.13.0",
    "typescript": "^5.4.5"
  }
}
